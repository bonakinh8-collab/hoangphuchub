local function TweenTo(targetCFrame, speed)
    speed = speed or 300
    local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    local dist = (hrp.Position - targetCFrame.Position).Magnitude
    if dist < 10 then 
        hrp.CFrame = targetCFrame
        return 
    end
    
    local bv = hrp:FindFirstChild("BodyClip")
    if not bv then
        bv = Instance.new("BodyVelocity")
        bv.Name = "BodyClip"
        bv.MaxForce = Vector3.new(100000, 100000, 100000)
        bv.Velocity = Vector3.new(0, 0, 0)
        bv.Parent = hrp
    end
    
    local ts = TweenService:Create(hrp, TweenInfo.new(dist/speed, Enum.EasingStyle.Linear), {CFrame = targetCFrame})
    ts:Play()
    ts.Completed:Wait()
    
    if bv then bv:Destroy() end
end

local function FastAttack(target)
    pcall(function()
        local hitPart = target:FindFirstChild("Head") or target:FindFirstChild("HumanoidRootPart")
        if not hitPart then return end
        local Net = rs:WaitForChild("Modules"):WaitForChild("Net")
        Net:WaitForChild("RE/RegisterAttack"):FireServer(0.1)
        Net:WaitForChild("RE/RegisterHit"):FireServer(hitPart, {{target, hitPart}})
    end)
end

local function EquipWeapon()
    pcall(function()
        for _, v in pairs(lp.Backpack:GetChildren()) do
            if v:IsA("Tool") and v.ToolTip == "Melee" then
                lp.Character.Humanoid:EquipTool(v)
                break
            end
        end
    end)
end

local function AutoKillMobs(mobNames)
    local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end

    local enemies = workspace:FindFirstChild("Enemies")
    if not enemies then return false end

    for _, v in pairs(enemies:GetChildren()) do
        local isTarget = false
        if type(mobNames) == "table" then
            for _, name in pairs(mobNames) do
                if v.Name:find(name) then isTarget = true; break end
            end
        else
            if v.Name:find(mobNames) then isTarget = true end
        end

        if isTarget and v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 and v:FindFirstChild("HumanoidRootPart") then
            hrp.CFrame = v.HumanoidRootPart.CFrame * CFrame.new(0, 5, 0)
            EquipWeapon()
            FastAttack(v)
            vim:SendKeyEvent(true, "Z", false, game)
            vim:SendKeyEvent(false, "Z", false, game)
            vim:SendKeyEvent(true, "X", false, game)
            vim:SendKeyEvent(false, "X", false, game)
            return true
        end
    end
    return false
end

-- ================= HUB LOGIC - COMPLETE TRIALS =================
local function AutoTrial()
    local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    local race = MyState.Race
    pcall(function()
        if race == "Mink" then
            if workspace.Map:FindFirstChild("MinkTrial") and workspace.Map.MinkTrial:FindFirstChild("Ceiling") then
                hrp.CFrame = workspace.Map.MinkTrial.Ceiling.CFrame * CFrame.new(0, -20, 0)
            end
        elseif race == "Cyborg" then
            if workspace.Map:FindFirstChild("CyborgTrial") and workspace.Map.CyborgTrial:FindFirstChild("Floor") then
                hrp.CFrame = workspace.Map.CyborgTrial.Floor.CFrame * CFrame.new(0, 500, 0)
            end
        elseif race == "Skypiea" or race == "Angel" then
            if workspace.Map:FindFirstChild("SkyTrial") and workspace.Map.SkyTrial:FindFirstChild("Model") then
                hrp.CFrame = workspace.Map.SkyTrial.Model.FinishPart.CFrame
            end
        elseif race == "Fishman" or race == "Shark" then
            local seaBeasts = workspace:FindFirstChild("SeaBeasts")
            if seaBeasts then
                for _, v in pairs(seaBeasts:GetChildren()) do
                    if v:FindFirstChild("HumanoidRootPart") and v:FindFirstChild("Health") and v.Health.Value > 0 then
                        hrp.CFrame = v.HumanoidRootPart.CFrame * CFrame.new(0, 300, 0)
                        EquipWeapon()
                        vim:SendKeyEvent(true, "Z", false, game)
                        vim:SendKeyEvent(true, "X", false, game)
                        vim:SendKeyEvent(true, "C", false, game)
                        break
                    end
                end
            end
        elseif race == "Human" or race == "Ghoul" then
            AutoKillMobs({"Ancient Vampire", "Ancient Zombie"})
        end
    end)
end

