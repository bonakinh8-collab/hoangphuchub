        (World3 and CheckBackPack("Red Key") and not CanAwakenDough()) or ScriptStorage.PlayerData.Level.Value <= 10 or getgenv().CurrentFarmTask == "Collecting Fruit" then
        return
    end
    if donttp then return end
    if Pos then
        if GetDistance(Pos) < 1000 then
            BypassingTP = false
            return
        end
        local ListPos = {}

        for _, v23 in next, workspace._WorldOrigin.Locations:GetChildren() do
            if BypassTpLocation[v23.Name] then
                for _, v25 in pairs(BypassTpLocation[v23.Name]) do
                    if not table.find(ListPos, v25[1]) then
                        table.insert(ListPos, v25[2])
                    end
                end;
            end
        end;
        if #ListPos == 0 then
            return
        end
        if #ListPos > 1 then
            table.sort(ListPos, function(a, b)
                return GetDistance(a, Pos) < GetDistance(b, Pos)
            end)
        end
        wait()
        local Found = false
        for i, v in pairs(ListPos) do
            if GetDistance(v, Pos) + 500 < GetDistance(Pos, Character) and GetDistance(v, LP.Character) >= 1000 then
                BypassingTP = true
                if CheckBackPack("Special Microchip") then return end
                if Character:FindFirstChild "LastSpawnPoint" then Character.LastSpawnPoint.Disabled = false end
                local SP, Tag = GetTPLocation(v)
                if Character:FindFirstChild('LastSpawnPoint') then game:GetService("Players").LocalPlayer.Character.LastSpawnPoint.Disabled = true end
                game.ReplicatedStorage.Remotes.CommF_:InvokeServer("SetLastSpawnPoint", SP);
                wait()
                if game.Players.LocalPlayer.Data.LastSpawnPoint.Value == SP then
                    game.Players.LocalPlayer.Character.Humanoid.Health = 0
                    game.Players.LocalPlayer.Character.Head:Destroy()
                    wait()
                    while not IsPlayerAlive() do
                        wait()
                    end
                    return SSS(Pos)
                end
            end
        end
        BypassingTP = false
        if Character:FindFirstChild('LastSpawnPoint') then game:GetService("Players").LocalPlayer.Character.LastSpawnPoint.Disabled = false end
    end
end


function TP1(pos, normal, Condition)
    local lastPauseTime = tick()
    local tween
    local count = tick()
    local Condition = Condition or function() return true end
    local Pos = CFrame.new(pos.X, pos.Y, pos.Z)
    if not IsPlayerAlive() then return end
    
    local r = game.Players.LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if r and q1(Pos.Position, r.Position) > 1000 then
        SSS(GetNearSpawn(Pos), normal)
        wait() -- Đợi một nhịp ngắn để ổn định sau khi SSS (Reset/Portal)
    end
    if game.Players.LocalPlayer.Character.Humanoid.Sit then 
    game.Players.LocalPlayer.Character.Humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
    end
    repeat
        wait()
        AddVelocity(true)
        if Noclipping then
            Noclipping:Disconnect()
            Noclipping = nil
        else
            Noclipping = game:GetService("RunService").Stepped:Connect(NoClip)
        end
        
        if not IsPlayerAlive() or not Condition() then
            if tween then 
                pcall(function()
                tween:Cancel() 
                tween = nil 
                end)
            end
            break
        end
        
        if tick() - lastPauseTime >= 10 then
            if tween then
                tween:Pause()
            end
            wait(.5)
            if tween then tween:Play() end
            lastPauseTime = tick()
        end
        
        if World3 then
            if GetDistance(Pos, CFrame.new(10439, -1962, 9697)) <= 5000 then
                if not workspace.Map:FindFirstChild('Submerged Island') then
                    if not workspace.NPCs:FindFirstChild('Submarine Worker') then
                        if tween then 
                            tween:Cancel() 
                            tween = nil 
                        end
                        TP1(CFrame.new(-16270, 25, 1374))
                    end
                    if workspace.NPCs:FindFirstChild('Submarine Worker') then
                        if tween then tween:Cancel() tween = nil end 
                        repeat
                            game:GetService("ReplicatedStorage").Modules.Net["RF/SubmarineWorkerSpeak"]:InvokeServer("TravelToSubmergedIsland")
                            wait(2)
                        until workspace.Map:FindFirstChild('Submerged Island') or not IsPlayerAlive()
                    end
                end
            end
        end
        
        local Distance = q1(Pos.Position, game.Players.LocalPlayer.Character.HumanoidRootPart.Position)
        if Pos.Position.Y > 0 then
            game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame = CFrame.new(
                game.Players.LocalPlayer.Character.HumanoidRootPart.Position.X,
                Pos.Position.Y,
                game.Players.LocalPlayer.Character.HumanoidRootPart.Position.Z
            )
            wait()
        end
        
        local Time = 0
        if Distance <= 200 then
            if Distance <= 50 then
                if tween then 
                    tween:Cancel() 
                    tween = nil 
                end
                game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame = Pos
                break
            else
                Time = 0.25
            end
        else
            Time = Distance / 300
        end
        if tween then
            tween:Cancel()
            tween = nil
        end
        
        tween = game:GetService("TweenService"):Create(
		 game.Players.LocalPlayer.Character.HumanoidRootPart,
            TweenInfo.new(Time, Enum.EasingStyle.Linear),
            { CFrame = Pos }
        )
        tween:Play()    
    until not IsPlayerAlive() or q1(Pos.Position, game.Players.LocalPlayer.Character.HumanoidRootPart.Position) < 3 or tick() - count >= 60
    
    if Noclipping then
        Noclipping:Disconnect()
        Noclipping = nil
    end
end


