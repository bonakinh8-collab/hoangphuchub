local CONFIG = nil
if getgenv and getgenv().Config then
    CONFIG = getgenv().Config
elseif _G.Config then
    CONFIG = _G.Config
else
    CONFIG = {
        MainAccounts = {"Main1", "Main2", "Main3", "Main4", "Main5", "Main6", "Main7", "Main8", "Main9", "Main10"},
        HelpAccounts = {"Help1", "Help2"}
    }
end

repeat task.wait() until game:IsLoaded()
repeat task.wait() until game.Players and game.Players.LocalPlayer
task.wait(2)

local Players = game:GetService("Players")
local HttpService = game:GetService("HttpService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local TeleportService = game:GetService("TeleportService")
local VirtualInput = game:GetService("VirtualInputManager")
local Workspace = game:GetService("Workspace")

local lp = Players.LocalPlayer
local rs = ReplicatedStorage
local CommF_ = rs:WaitForChild("Remotes"):WaitForChild("CommF_")

-- ================= TEAM & HAKI =================
task.spawn(function()
    while task.wait(1) do
        local lp = Players.LocalPlayer
        if lp and (not lp.Team or lp.Team.Name ~= "Pirates") then
            pcall(function()
                CommF_:InvokeServer("SetTeam", "Pirates")
            end)
        else
            break
        end
    end
    
    local char = Players.LocalPlayer.Character
    pcall(function()
        if not char or not char:FindFirstChild("HasBuso") then
            CommF_:InvokeServer("Buso")
        end
    end)
end)

-- ================= SYNC ENGINE (LOCAL FILES) =================
local SyncFolder = "KaitunV4_Sync"
if not isfolder(SyncFolder) then makefolder(SyncFolder) end

local JobIdStr = game.JobId
if JobIdStr == "" then JobIdStr = "PrivateServer" end
local ServerFolder = SyncFolder .. "/" .. JobIdStr
if not isfolder(ServerFolder) then makefolder(ServerFolder) end

local function WriteStatus(statusData)
    local path = ServerFolder .. "/" .. lp.Name .. ".json"
    pcall(function()
        writefile(path, HttpService:JSONEncode(statusData))
    end)
end

local function ReadStatus(playerName)
    local path = ServerFolder .. "/" .. playerName .. ".json"
    local data = nil
    pcall(function()
        if isfile(path) then
            local content = readfile(path)
            data = HttpService:JSONDecode(content)
        end
    end)
    return data
end

-- ================= ROLE & STATE =================
local MyRole = "None"
for _, name in ipairs(CONFIG.MainAccounts) do
    if name == lp.Name then MyRole = "Main" end
end
for _, name in ipairs(CONFIG.HelpAccounts) do
    if name == lp.Name then MyRole = "Help" end
end

local MyState = {
    Role = MyRole,
    Phase = "Init", -- Init, Waiting, AtDoor, InTrial, InPvP, Dead, Done
    Race = "Unknown",
    JobId = JobIdStr,
    LastUpdate = os.time()
}

local function UpdatePhase(phase)
    MyState.Phase = phase
    MyState.LastUpdate = os.time()
    WriteStatus(MyState)
    print("[KaitunV4] Phase changed to: " .. phase)
end

-- ================= RACE DOORS & TELEPORT =================
local RaceDoors = {
    ["Mink"]    = CFrame.new(29020.66, 14889.42, -379.26),
    ["Fishman"] = CFrame.new(28224.05, 14889.42, -210.58),
    ["Cyborg"]  = CFrame.new(28492.41, 14894.42, -422.11),
    ["Skypiea"] = CFrame.new(28967.40, 14918.07, 234.31),
    ["Ghoul"]   = CFrame.new(28672.72, 14889.12, 454.59),
    ["Human"]   = CFrame.new(29237.29, 14889.42, -206.94)
}

local ANCIENT_CLOCK_POS = CFrame.new(29549, 15069, -88)
local ANCIENT_ONE_POS = CFrame.new(28981.55, 14888.42, -120.24)
local TEMPLE_ENTRANCE = Vector3.new(-12538.42, 340.89, -7817.07)

local function GetMyRace()
    local success, data = pcall(function() return lp.Data.Race.Value end)
    if success and data then
        MyState.Race = tostring(data)
        return tostring(data)
    end
    return "Unknown"
end

local function TweenTo(cframe, speed)
    speed = speed or 300
    local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local dist = (hrp.Position - cframe.Position).Magnitude
    if dist < 10 then hrp.CFrame = cframe; return end
    
    local ts = TweenService:Create(hrp, TweenInfo.new(dist/speed, Enum.EasingStyle.Linear), {CFrame = cframe})
    ts:Play()
    ts.Completed:Wait()
end

local function BypassToTemple()
    CommF_:InvokeServer("requestEntrance", TEMPLE_ENTRANCE)
end

local function AutoTrial()
    local char = lp.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not char or not hrp then return end
    
    local race = MyState.Race
    
    pcall(function()
        if race == "Mink" then
            -- Bypass mê cung thỏ
            if Workspace.Map:FindFirstChild("MinkTrial") and Workspace.Map.MinkTrial:FindFirstChild("Ceiling") then
                hrp.CFrame = Workspace.Map.MinkTrial.Ceiling.CFrame * CFrame.new(0, -20, 0)
            end
            
        elseif race == "Cyborg" then
            -- Né tên lửa bằng cách bay lên trời
            if Workspace.Map:FindFirstChild("CyborgTrial") and Workspace.Map.CyborgTrial:FindFirstChild("Floor") then
                hrp.CFrame = Workspace.Map.CyborgTrial.Floor.CFrame * CFrame.new(0, 500, 0)
            end
            
        elseif race == "Skypiea" then
            -- Dịch chuyển thẳng tới đích nhảy mây
            if Workspace.Map:FindFirstChild("SkyTrial") and Workspace.Map.SkyTrial:FindFirstChild("Model") then
                hrp.CFrame = Workspace.Map.SkyTrial.Model.FinishPart.CFrame
            end
            
        elseif race == "Fishman" then
            -- Trial Cá (Shark): Đánh SeaBeast
            local seaBeasts = Workspace:FindFirstChild("SeaBeasts")
            if seaBeasts then
                for _, v in pairs(seaBeasts:GetChildren()) do
                    if v:FindFirstChild("HumanoidRootPart") and v:FindFirstChild("Health") and v.Health.Value > 0 then
                        -- Bay lên trên đầu SeaBeast xả skill
                        hrp.CFrame = v.HumanoidRootPart.CFrame * CFrame.new(0, 150, 0)
                        
                        -- Spam skills
                        VirtualInput:SendKeyEvent(true, "Z", false, game)
                        VirtualInput:SendKeyEvent(false, "Z", false, game)
                        VirtualInput:SendKeyEvent(true, "X", false, game)
                        VirtualInput:SendKeyEvent(false, "X", false, game)
                        VirtualInput:SendKeyEvent(true, "C", false, game)
                        VirtualInput:SendKeyEvent(false, "C", false, game)
                    end
                end
            end
            
        elseif race == "Human" or race == "Ghoul" then
            -- Đánh quái (Zombie, Vampire, Boss, SeaBeast)
            -- Logic đánh chung: Quét toàn bộ Enemies gần đó trong phòng Trial và tự động vả
            local enemies = Workspace:FindFirstChild("Enemies")
            if enemies then
                for _, v in pairs(enemies:GetChildren()) do
                    if v:FindFirstChild("HumanoidRootPart") and v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 then
                        local dist = (hrp.Position - v.HumanoidRootPart.Position).Magnitude
                        -- Nếu quái ở gần (trong bán kính phòng trial)
                        if dist < 300 then
                            -- Dịch chuyển ra sau lưng quái
                            hrp.CFrame = v.HumanoidRootPart.CFrame * CFrame.new(0, 30, 0)
                            
                            -- Spam click/skill
                            VirtualInput:SendKeyEvent(true, "Z", false, game)
                            VirtualInput:SendKeyEvent(false, "Z", false, game)
                            VirtualInput:SendKeyEvent(true, "X", false, game)
                            VirtualInput:SendKeyEvent(false, "X", false, game)
                            
                            -- Tận dụng FastAttack nếu được nhúng vào
                            pcall(function()
                                local hitPart = v:FindFirstChild("Head") or v.HumanoidRootPart
                                local RegisterAttack = ReplicatedStorage:WaitForChild("Modules"):WaitForChild("Net"):WaitForChild("RE/RegisterAttack")
                                local RegisterHit = ReplicatedStorage:WaitForChild("Modules"):WaitForChild("Net"):WaitForChild("RE/RegisterHit")
                                RegisterAttack:FireServer(0.1)
                                RegisterHit:FireServer(hitPart, {{v, hitPart}})
                            end)
                        end
                    end
                end
            end
        end
    end)
end

-- ================= CONDITIONS CHECK =================
local function isFullMoon()
    return game:GetService("Lighting"):GetAttribute("MoonPhase") == 5
end

local function GetActiveMain()
    for _, mainName in ipairs(CONFIG.MainAccounts) do
        local st = ReadStatus(mainName)
        if not st or st.Phase ~= "Done" then
            return mainName
        end
    end
    return nil
end

local function IsInPvP()
    local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    -- Check if close to Ancient Clock
    return (hrp.Position - ANCIENT_CLOCK_POS.Position).Magnitude < 150
end

local function PressV3()
    VirtualInput:SendKeyEvent(true, "T", false, game)
    task.wait(0.1)
    VirtualInput:SendKeyEvent(false, "T", false, game)
    -- Also press Y just in case V4 is needed
    VirtualInput:SendKeyEvent(true, "Y", false, game)
    task.wait(0.1)
    VirtualInput:SendKeyEvent(false, "Y", false, game)
end

local function PullLever()
    CommF_:InvokeServer("templedoorcheck")
end

-- ================= HELP ACC LOGIC =================
local function HelpLoop()
    while task.wait(1) do
        local char = lp.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        if not char or not hrp then continue end

        local activeMain = GetActiveMain()
        if not activeMain then
            UpdatePhase("Done")
            continue
        end

        local mainStatus = ReadStatus(activeMain)
        if not mainStatus then continue end

        GetMyRace()

        if IsInPvP() then
            UpdatePhase("InPvP")
            -- Đợi Active Main xuất hiện ở phòng PvP
            local mainPlayer = Players:FindFirstChild(activeMain)
            if mainPlayer and mainPlayer.Character and mainPlayer.Character:FindFirstChild("HumanoidRootPart") then
                local dist = (mainPlayer.Character.HumanoidRootPart.Position - hrp.Position).Magnitude
                if dist < 200 then
                    print("🔪 Thấy Main trong PvP -> Tự sát!")
                    lp.Character:BreakJoints()
                    if lp.Character:FindFirstChild("Humanoid") then
                        lp.Character.Humanoid.Health = 0
                    end
                    UpdatePhase("Dead")
                    task.wait(5)
                end
            end
            continue
        end

        -- Nếu đang sống và không ở PvP
        if mainStatus.Phase == "WaitingForMoon" or mainStatus.Phase == "AtDoor" or mainStatus.Phase == "InTrial" then
            
            -- Nếu Main đang trong Trial, Help cũng tự vượt ải của mình
            if mainStatus.Phase == "InTrial" then
                UpdatePhase("InTrial")
                AutoTrial()
                continue
            end
            
            BypassToTemple()
            task.wait(1)
            local doorPos = RaceDoors[MyState.Race]
            if doorPos then
                TweenTo(doorPos)
                UpdatePhase("AtDoor")
            end
            
            -- Đồng bộ bật V3
            if mainStatus.Phase == "AtDoor" and isFullMoon() then
                -- Đợi tí để khớp nhịp
                task.wait(math.random() * 0.5) 
                PressV3()
            end
        else
            UpdatePhase("Waiting")
            -- Nếu Main đi farm, help đứng im
            if (hrp.Position - TEMPLE_ENTRANCE).Magnitude > 500 then
                BypassToTemple()
            end
        end
    end
end

-- ================= MAIN ACC LOGIC =================
local function MainLoop()
    while task.wait(1) do
        local activeMain = GetActiveMain()
        
        -- Nếu đã max V4
        if MyState.Phase == "Done" then
            continue
        end
        
        if activeMain ~= lp.Name then
            UpdatePhase("Waiting")
            continue
        end
        
        local char = lp.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        if not char or not hrp then continue end
        
        GetMyRace()

        -- Check Training (Tái sử dụng logic Check V4 từ v4_auto_train)
        local a, b = CommF_:InvokeServer("UpgradeRace","Check")
        if a == 5 then
            UpdatePhase("Done")
            print("🎉 MAX V4 CHUYỂN ACC TIẾP THEO!")
            continue
        end

        if IsInPvP() then
            UpdatePhase("InPvP")
            -- Check xem 2 Help đã chết chưa
            local help1Status = ReadStatus(CONFIG.HelpAccounts[1])
            local help2Status = ReadStatus(CONFIG.HelpAccounts[2])
            
            if (not help1Status or help1Status.Phase == "Dead") and (not help2Status or help2Status.Phase == "Dead") then
                print("🏆 Đã thắng PvP, đợi game chuyển tới Ancient One")
                task.wait(5)
            end
            continue
        end
        
        -- Nếu cần Trial
        if a == 0 or a == 2 or a == 4 or a == 7 then
            -- Mua gear nếu có thể
            if a == 2 or a == 4 or a == 7 then
                CommF_:InvokeServer("UpgradeRace", "Buy")
                task.wait(1)
                CommF_:InvokeServer("UpgradeRace", "Buy", 2)
            end

            -- Chờ Full Moon và vào Trial
            BypassToTemple()
            task.wait(1)
            local doorPos = RaceDoors[MyState.Race]
            if doorPos then
                TweenTo(doorPos)
            end
            
            -- Check 2 Help đã ở cửa chưa
            local h1 = ReadStatus(CONFIG.HelpAccounts[1])
            local h2 = ReadStatus(CONFIG.HelpAccounts[2])
            
            if h1 and h1.Phase == "AtDoor" and h2 and h2.Phase == "AtDoor" then
                if isFullMoon() then
                    UpdatePhase("AtDoor") -- Tín hiệu cho Help bấm V3
                    task.wait(1)
                    PressV3()
                    task.wait(1)
                    PullLever()
                    
                    UpdatePhase("InTrial")
                    local trialTimeout = tick() + 60 -- 1 phút vượt ải max
                    while tick() < trialTimeout do
                        -- Nếu đã bị ném vào phòng PvP thì break
                        if IsInPvP() then break end
                        
                        AutoTrial()
                        task.wait(0.5)
                    end
                else
                    UpdatePhase("WaitingForMoon")
                end
            else
                UpdatePhase("WaitingForHelps")
            end
            continue
        end
        
        -- Nếu cần Train
        if a == 1 or a == 3 or a == 6 or a == 8 then
            UpdatePhase("Training")
            -- Chỗ này sẽ load logic farm mob xương từ file v4_auto_train.txt
            -- Để file gọn gàng, ta require hoặc loadstring file đó
            -- (Chi tiết triển khai sau)
            print("⚔️ Bắt đầu đi farm quái xương để Train...")
            task.wait(5)
        end
    end
end

-- ================= ENTRY POINT =================
GetMyRace()
WriteStatus(MyState)
print("🚀 Khởi động Kaitun Race V4 cho: " .. lp.Name .. " | Role: " .. MyRole)

if MyRole == "Help" then
    task.spawn(HelpLoop)
elseif MyRole == "Main" then
    task.spawn(MainLoop)
end
