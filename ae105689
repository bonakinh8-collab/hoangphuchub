-- ================= SYNC SYSTEM (Local File) =================
local FILE_NAME = "V4_SYNC.json"
local HttpService = game:GetService("HttpService")

local function ReadSync()
    if not isfile(FILE_NAME) then writefile(FILE_NAME, HttpService:JSONEncode({})) end
    local ok, data = pcall(function() return HttpService:JSONDecode(readfile(FILE_NAME)) end)
    if ok and type(data) == "table" then return data end
    return {}
end

local function WriteSync(data)
    pcall(function() writefile(FILE_NAME, HttpService:JSONEncode(data)) end)
end

local function UpdatePhase(phase)
    MyState.Phase = phase
    local data = ReadSync()
    data[lp.Name] = { Role = MyState.Role, Phase = phase, Tick = tick() }
    WriteSync(data)
end

local function GetActiveMain()
    local data = ReadSync()
    local mains = {}
    for name, info in pairs(data) do
        if info.Role == "Main" and info.Phase ~= "Done" and (tick() - info.Tick < 10) then
            table.insert(mains, name)
        end
    end
    table.sort(mains, function(a, b)
        local ia, ib = 99, 99
        for i, n in ipairs(CONFIG.MainAccounts) do if n == a then ia = i break end end
        for i, n in ipairs(CONFIG.MainAccounts) do if n == b then ib = i break end end
        return ia < ib
    end)
    return mains[1]
end

local function isFullMoon()
    return game:GetService("Lighting").Sky.MoonTextureId == "http://www.roblox.com/asset/?id=9709149431"
end

-- ================= MAIN LOOP =================
local function MainLoop()
    local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local ok, a = pcall(function() return CommF_:InvokeServer("UpgradeRace", "Check") end)
    if not ok then return end
    
    if a == 5 then
        UpdatePhase("Done")
        return
    end

    if a == 1 or a == 3 or a == 6 or a == 8 then
        UpdatePhase("Farming")
        local farmPos = CFrame.new(-9495.68, 453.58, 5977.34)
        if (hrp.Position - farmPos.Position).Magnitude > 300 then
            TweenTo(farmPos)
        else
            local isFarming = AutoKillMobs({"Reborn Skeleton", "Living Zombie", "Demonic Soul", "Posessed Mummy"})
            if not isFarming then hrp.CFrame = farmPos end
            
            pcall(function()
                if lp.Character:FindFirstChild("RaceEnergy") and lp.Character.RaceEnergy.Value >= 1 then
                    vim:SendKeyEvent(true, "Y", false, game)
                    task.wait(0.1)
                    vim:SendKeyEvent(false, "Y", false, game)
                end
            end)
        end
        return
    end

    if a == 0 or a == 2 or a == 4 or a == 7 then
        local activeMain = GetActiveMain()
        if activeMain ~= lp.Name then
            UpdatePhase("WaitingTurn")
            return
        end

        if a == 2 or a == 4 or a == 7 then
            CommF_:InvokeServer("UpgradeRace", "Buy")
            task.wait(1)
            CommF_:InvokeServer("UpgradeRace", "Buy", 2)
        end

        if IsInPvP() then
            UpdatePhase("InPvP")
            local enemiesAlive = false
            for _, v in pairs(game.Players:GetPlayers()) do
                if v ~= lp and v.Character and v.Character:FindFirstChild("Humanoid") and v.Character.Humanoid.Health > 0 then
                    local vhrp = v.Character:FindFirstChild("HumanoidRootPart")
                    if vhrp and (vhrp.Position - hrp.Position).Magnitude < 300 then
                        enemiesAlive = true
                        hrp.CFrame = vhrp.CFrame * CFrame.new(0, 0, 5)
                        EquipWeapon()
                        FastAttack(v.Character)
                    end
                end
            end
            if not enemiesAlive then
                hrp.CFrame = CFrame.new(28981.55, 14888.42, -120.24)
                task.wait(1)
                PullLever()
            end
            return
        end

        BypassToTemple()
        local doorPos = RaceDoors[MyState.Race]
        if doorPos then 
            if (hrp.Position - doorPos.Position).Magnitude < 3000 then
                hrp.CFrame = doorPos
            else
                TweenTo(doorPos)
            end
        end

        local syncData = ReadSync()
        local helpsAtDoor = 0
        for _, name in pairs(CONFIG.HelpAccounts) do
            if syncData[name] and syncData[name].Phase == "AtDoor" and (tick() - syncData[name].Tick < 10) then
                helpsAtDoor = helpsAtDoor + 1
            end
        end

        if helpsAtDoor >= 2 then
            if isFullMoon() then
                UpdatePhase("Pulling")
                vim:SendKeyEvent(true, "T", false, game)
                task.wait(1)
                PullLever()
                task.wait(1)
                AutoTrial()
            else
                UpdatePhase("WaitingMoon")
            end
        else
            UpdatePhase("WaitingHelps")
        end
    end
end

-- ================= HELP LOOP =================
local function HelpLoop()
    local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local syncData = ReadSync()
    local mainPhase = "INIT"
    for _, name in pairs(CONFIG.MainAccounts) do
        if syncData[name] and (tick() - syncData[name].Tick < 10) and syncData[name].Phase ~= "Done" then
            mainPhase = syncData[name].Phase
            break
        end
    end

    if IsInPvP() then
        SelfDestruct()
        UpdatePhase("Dead")
        return
    end

    BypassToTemple()
    local doorPos = RaceDoors[MyState.Race]
    if doorPos then
        if (hrp.Position - doorPos.Position).Magnitude > 5 then
            if (hrp.Position - doorPos.Position).Magnitude < 3000 then
                hrp.CFrame = doorPos
            else
                TweenTo(doorPos)
            end
        end
        UpdatePhase("AtDoor")
    end

    if mainPhase == "Pulling" then
        vim:SendKeyEvent(true, "T", false, game)
    elseif mainPhase == "InPvP" then
        SelfDestruct()
    end
end

